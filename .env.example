# ── Database ──────────────────────────────────────────────────────────────────
# cPanel → MySQL Databases → your DB / user credentials
# Note: cPanel auto-prefixes DB names and users with your cPanel username.
DB_HOST=localhost
DB_NAME=cpanelusername_dbname
DB_USER=cpanelusername_user
DB_PASS=your_strong_db_password

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Plain-text password works out of the box (quick start).
# To upgrade to a bcrypt hash (recommended on production):
#   php -r "echo password_hash('YourPassword', PASSWORD_BCRYPT);"
# Paste the output (starts with $2y$) as ADMIN_PASS — admin.php auto-detects.
ADMIN_USER=admin
ADMIN_PASS=changeme
